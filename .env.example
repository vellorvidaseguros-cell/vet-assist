# Variáveis de Ambiente - VetAssist
# Copie este arquivo para .env e preencha os valores

# Ambiente (development | production)
NODE_ENV=production

# Porta do servidor (Railway define automaticamente)
PORT=5000

# Banco de dados PostgreSQL (Railway provisiona automaticamente)
# Deixe vazio para usar SQLite em desenvolvimento local
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT (gere uma chave forte para produção)
JWT_SECRET=sua_chave_jwt_super_secreta_aqui

# URL do frontend (para CORS em produção)
FRONTEND_URL=https://seu-app.railway.app
